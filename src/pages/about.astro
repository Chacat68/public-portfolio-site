---
import BlogPostLayout from "../layouts/BlogPostLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import CallToAction from "../components/CallToAction.astro";
import {pageTag, pageDescription,aboutTdk} from '../data/content';

const portraitUrl = 'https://blog-1259751088.cos.ap-shanghai.myqcloud.com/20260624134214913.webp?imageSlim';
---
<BlogPostLayout
	title={aboutTdk.title || ''}
	description = {aboutTdk.description || ''}
	keywords = {aboutTdk.keywords || ''}
>

	<div class="post">
		<main class="post-wrapper about">
			<SectionHeader
				tag={pageTag.about}
				description={pageDescription.about}>
				 关于我
			</SectionHeader>
			<section class="border-top" style="padding-top: 2rem;">
				<div class="content">
					<div style="text-align:center">
						<img src={portraitUrl} alt="portrait" width="88" height="88" class="portrait" />
					</div>
					<p>
						我是 <strong style="font-size:1.2em">王权</strong>，一名摄影师，专注于用镜头捕捉光影、记录瞬间。从街头纪实到人像创作，我始终在寻找画面中那个恰到好处的时刻。
					</p>
					<p>
						目前我在持续拍摄和创作，探索视觉叙事的不同可能性——每一张照片都是一个独立的故事。
					</p>

				</div>
			</section>
			<section>
				<h3 class="post-title">工作之外</h3>
				<div class="content">
					<p>
						除了日常拍摄之外，我喜欢将空闲时间投入到个人项目中——整理作品集、研究后期技术、探索不同器材的表现力。也喜欢在城市里漫无目的地走，带着相机，看看会撞见什么。
					</p>
					<p>如果你也喜欢摄影，欢迎交流。</p>
					<p style="margin-top:24px;">
						<CallToAction
							target="_self"
							href="mailto:colinwangq@163.com"
						>
							联系我
						</CallToAction>
					</p>
				</div>
			</section>
			<p></p>
			<p></p>
		</main>
	</div>
</BlogPostLayout>

<style>
	.about {
		display: flex;
		flex-direction: column;
		margin:0 auto;
	}
	p{
		margin:0.75rem 0;
	}
	figure{
		margin:2rem 0;
	}
	img{max-width: 100%;}
	.portrait{
		border-radius: 100px;
		margin:12px 0 12px;
		overflow: hidden;
		text-align: left;
	}
	a, a:link{
		color:var(--color-blue);
	}
</style>
